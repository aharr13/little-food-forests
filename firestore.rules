rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers -------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    // Admin = the wiki/plant-database maintainer. UID is found in
    // Firebase Console → Authentication → Users (aharr13@gmail.com).
    function isAdmin() {
      return isSignedIn()
        && request.auth.uid == 'AzE3BYGCbefVle0FmKm6MFt961x2';
    }
    // A user "owns" a document if its userId field matches their auth uid.
    function ownsExisting() {
      return isSignedIn() && request.auth.uid == resource.data.userId;
    }
    function ownsIncoming() {
      return isSignedIn() && request.auth.uid == request.resource.data.userId;
    }

    // ---- Default: deny everything not explicitly allowed ---------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---- Per-user data (owner-only) ------------------------------------
    // Each document carries a userId field; only its owner may touch it.
    match /projects/{projectId} {
      allow read, update, delete: if ownsExisting();
      allow create: if ownsIncoming();
    }

    match /tasks/{taskId} {
      allow read, update, delete: if ownsExisting();
      allow create: if ownsIncoming();
    }

    match /careItems/{itemId} {
      allow read, update, delete: if ownsExisting();
      allow create: if ownsIncoming();
    }

    match /photoReminders/{reminderId} {
      allow read, update, delete: if ownsExisting();
      allow create: if ownsIncoming();
    }

    // ---- Shared, read-only catalogs (admin-curated) --------------------
    // Any signed-in user can read; only the admin can modify.
    // NOTE: the Node seed scripts in src/components/Canvas/scripts use the
    // client SDK unauthenticated, so they cannot write under these rules.
    // Re-seed via the Firebase Admin SDK, or temporarily relax `write`.
    match /plants/{plantId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /wiki/{articleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
