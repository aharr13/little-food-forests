rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default: deny everything not explicitly allowed
    match /{document=**} {
      allow read, write: if false;
    }

    // Projects — users can only access their own
    match /projects/{projectId} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }

    // Planting tasks — userId stored on each document, queried by userId
    match /tasks/{taskId} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }

    // Recurring care items — same pattern as tasks
    match /careItems/{itemId} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }

    // Wiki articles — any authenticated user can read; writes are admin-only
    // To grant admin write access, add specific UIDs to the condition below
    match /wikiArticles/{articleId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == 'AzE3BYGCbefVle0FmKm6MFt961x2'; // find this in Firebase Console → Authentication → Users
    }
  }
}
