# Copy to .env.local and fill in. All VITE_* values are Firebase *web* config
# and a Google Maps browser key — these are safe to expose in a client bundle;
# access is controlled by Firestore/Storage security rules and HTTP referrer
# restrictions, NOT by hiding these values.
#
# The Anthropic API key is intentionally NOT here. It lives only on the server,
# set as a Firebase secret:  firebase functions:secrets:set ANTHROPIC_API_KEY

# --- Firebase web app config (Project settings → Your apps → SDK setup) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Google Maps JavaScript API (restrict by HTTP referrer in the console) ---
VITE_GOOGLE_MAPS_API_KEY=
