rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Project photos live at projects/{userId}/{projectId}/photos/...
    // Only the owning user may read or write their own files.
    match /projects/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId
        // Cap uploads at 15MB to avoid runaway storage costs.
        && (request.resource == null || request.resource.size < 15 * 1024 * 1024);
    }

    // Everything else: deny.
    match /{allOther=**} {
      allow read, write: if false;
    }
  }
}
